# 21st.dev Registry / Magic MCP key.
# Keep the real value only in .env.local or in deployment provider variables.
API_KEY_21ST="[COLLER_TA_CLE_API_ICI]"

# Optional legacy alias if a tool expects this name.
21ST_API_KEY=""

# --- Formulaire de contact (envoi d'email via Resend) ---
# Sur Vercel, tu n'as besoin QUE de RESEND_API_KEY. Les deux autres sont OPTIONNELLES.
# 1. Compte gratuit sur https://resend.com avec ton email (tchoupimr@gmail.com).
# 2. API key sur https://resend.com/api-keys.
# 3. Colle-la dans .env.local (local) ET dans Vercel > Settings > Environment Variables.
# Sans cette clé, le formulaire bascule sur le fallback email/Discord.
RESEND_API_KEY=""

# OPTIONNEL — par défaut le code envoie à tchoupimr@gmail.com.
# (onboarding@resend.dev ne livre qu'à l'adresse du compte Resend tant qu'aucun
#  domaine n'est vérifié.)
CONTACT_TO_EMAIL=""

# OPTIONNEL — par défaut "17Lud Studio <onboarding@resend.dev>".
# Une fois un domaine vérifié sur Resend, mets par ex. "17Lud <contact@tondomaine.com>".
CONTACT_FROM_EMAIL=""
