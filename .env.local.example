# 21st.dev Registry / Magic MCP key.
# Keep the real value only in .env.local or in deployment provider variables.
API_KEY_21ST="[COLLER_TA_CLE_API_ICI]"

# Optional legacy alias if a tool expects this name.
21ST_API_KEY=""

# --- Formulaire de contact (envoi d'email via Resend) ---
# 1. Crée un compte gratuit sur https://resend.com avec ton email (ludofootball@icloud.com).
# 2. Copie une API key depuis https://resend.com/api-keys.
# 3. Colle-la ici en local ET dans Vercel > Project > Settings > Environment Variables.
# Sans cette clé, le formulaire fonctionne mais bascule sur le fallback email/Discord.
RESEND_API_KEY=""

# Email qui reçoit les demandes (défaut : ludofootball@icloud.com).
CONTACT_TO_EMAIL=""

# Expéditeur. Laisse vide pour utiliser l'expéditeur partagé Resend
# "onboarding@resend.dev" (n'envoie qu'à l'adresse de ton compte Resend).
# Une fois un domaine vérifié sur Resend, mets par ex. "17Lud <contact@tondomaine.com>".
CONTACT_FROM_EMAIL=""
